# Configure ISP1 (eno1)

[Match]

Name=eno1

  ##ISP NAME##

[Network]

DHCP=ipv4

IPForward=yes

IPMasquerade=yes

  

[DHCP]

RouteTable=1       # Use routing table 1

RouteMetric=100    # Match script's metric

  

[RoutingPolicyRule]

From=192.168.1.0/24  # Actual network for eno1

Table=1

Priority=100
